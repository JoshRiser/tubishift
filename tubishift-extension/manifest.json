{
  "manifest_version": 3,
  "name": "TubiShift",
  "version": "1.0",
  "description": "Auto-advance through your TubiShift channel queue while watching on Tubi.",

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webNavigation"
  ],

  "host_permissions": [
    "https://tubitv.com/*",
    "http://localhost:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://tubitv.com/*"],
      "js": ["navigate.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://tubitv.com/tv-shows/*"],
      "js": ["player.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "TubiShift"
  },

  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}